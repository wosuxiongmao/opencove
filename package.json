{
  "name": "opencove",
  "version": "0.2.0",
  "productName": "OpenCove",
  "description": "Your infinite canvas workspace for agents, tasks, knowledge, and research.",
  "main": "./out/main/index.js",
  "author": {
    "name": "deadwavewave",
    "email": "deadwavewave@gmail.com"
  },
  "publisher": "DeadWaveWave",
  "license": "MIT",
  "homepage": "https://github.com/DeadWaveWave/opencove#readme",
  "bugs": {
    "url": "https://github.com/DeadWaveWave/opencove/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeadWaveWave/opencove.git"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ai-agent",
    "claude-code",
    "codex",
    "developer-tools"
  ],
  "build": {
    "appId": "dev.deadwave.opencove",
    "productName": "OpenCove",
    "executableName": "OpenCove",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "check": "tsc --noEmit",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:mac:unsigned": "pnpm build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/test-e2e-with-window-fallback.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "secret-check:staged": "node scripts/check-secrets-staged.mjs",
    "secrets:scan": "secretlint \"**/*\"",
    "line-check:staged": "node scripts/check-max-lines.mjs",
    "release:patch": "node scripts/prepare-release.mjs patch",
    "release:minor": "node scripts/prepare-release.mjs minor",
    "release:major": "node scripts/prepare-release.mjs major",
    "release:version": "node scripts/prepare-release.mjs",
    "pre-commit": "pnpm line-check:staged && pnpm secret-check:staged && pnpm lint:fix && pnpm format:check && pnpm check && pnpm test -- --run && pnpm test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.5.9",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.58.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "dmg-builder": "^26.8.1",
    "drizzle-kit": "^0.31.8",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.43.0",
    "prettier": "^3.8.1",
    "secretlint": "^11.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "node scripts/check-max-lines.mjs",
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less,html,json,md,yaml,yml}": [
      "node scripts/check-max-lines.mjs",
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,css,scss,less,html,json,md,yaml,yml,env,sh,txt}": [
      "node scripts/check-secrets-staged.mjs"
    ]
  },
  "pnpm": {
    "overrides": {
      "ajv@6.12.6": "6.14.0",
      "ajv@8.17.1": "8.18.0",
      "esbuild@0.18.20": "0.25.12",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@5.1.6": "5.1.8",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.1.2": "10.2.3"
    }
  }
}
